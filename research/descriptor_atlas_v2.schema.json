{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wondercodex.com/research/descriptor-atlas-v2.schema.json",
  "title": "Wonder Codex Descriptor Atlas v2",
  "type": "object",
  "required": ["schema", "independence", "mappings"],
  "properties": {
    "schema": {"const": "wonder-codex-descriptor-atlas/v2"},
    "independence": {
      "type": "object",
      "required": ["thirdPartyTablesCopied", "projectorEvidenceRequired"],
      "properties": {
        "thirdPartyTablesCopied": {"const": false},
        "projectorEvidenceRequired": {"const": true}
      },
      "additionalProperties": false
    },
    "mappings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["token", "family", "visualPart", "status", "messageIds"],
        "properties": {
          "token": {"type": "string", "pattern": "^[A-Z0-9_]{1,100}$"},
          "family": {"type": "string", "pattern": "^[A-Z0-9_]{1,120}$"},
          "visualPart": {"type": "string", "minLength": 1, "maxLength": 80},
          "variant": {"type": "string", "maxLength": 120},
          "status": {"enum": ["candidate", "projector_correlated", "specimen_confirmed", "disputed"]},
          "messageIds": {"type": "array", "items": {"type": "string"}, "minItems": 1},
          "evidenceNotes": {"type": "string", "maxLength": 1000}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
