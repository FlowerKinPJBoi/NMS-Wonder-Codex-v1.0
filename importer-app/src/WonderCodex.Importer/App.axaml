<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WonderCodex.Importer.App"
             RequestedThemeVariant="Dark">
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Window">
      <Setter Property="Background" Value="#070B19" />
      <Setter Property="FontFamily" Value="Inter" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#67DDF2" />
      <Setter Property="Foreground" Value="#031019" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="18,11" />
    </Style>
    <Style Selector="Button.secondary">
      <Setter Property="Background" Value="#151C35" />
      <Setter Property="Foreground" Value="#F4F7FF" />
      <Setter Property="BorderBrush" Value="#34446C" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="18,11" />
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="#10162A" />
      <Setter Property="BorderBrush" Value="#283658" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style Selector="TextBlock.kicker">
      <Setter Property="Foreground" Value="#67DDF2" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
      <Setter Property="LetterSpacing" Value="2" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="#AAB6D3" />
    </Style>
  </Application.Styles>
</Application>
